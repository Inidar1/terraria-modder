<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TerrariaModManager.ViewModels"
             x:Class="TerrariaModManager.Views.DownloadsView"
             x:DataType="vm:DownloadsViewModel">
    <Grid Margin="24,24,24,36" RowDefinitions="Auto,*">

        <TextBlock Text="Downloads" Classes="section-header" Grid.Row="0"/>

        <Border Grid.Row="1" Classes="card">
            <Grid>
                <TextBlock Text="No downloads yet.&#x0a;Click 'Download with Vortex' on Nexus Mods to start."
                           Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsVisible="{Binding !Downloads.Count}"/>

                <ListBox ItemsSource="{Binding Downloads}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="12,12,12,16"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderColorBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                        <Style Selector="ListBoxItem:last-child">
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:DownloadItem">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                <!-- Top Row: Name and Action -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <Button Content="Nexus Page" FontSize="10" Padding="8,2" Margin="12,0,0,0"
                                            Classes="secondary" VerticalAlignment="Center"
                                            Command="{Binding $parent[UserControl].DataContext.OpenOnNexusCommand}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>

                                <!-- Status Label (Top Right) -->
                                <Border Grid.Row="0" Grid.Column="1" Padding="6,2" CornerRadius="4" VerticalAlignment="Center"
                                        Background="{StaticResource BgDarkBrush}">
                                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Styles>
                                            <Style Selector="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            </Style>
                                            <Style Selector="TextBlock[Text=Installed]">
                                                <Setter Property="Foreground" Value="#FF58EB1C"/>
                                            </Style>
                                            <Style Selector="TextBlock[Text=Installing...]">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </Style>
                                            <Style Selector="TextBlock[Text=Install Failed]">
                                                <Setter Property="Foreground" Value="#FFE05252"/>
                                            </Style>
                                            <Style Selector="TextBlock[Text=Failed]">
                                                <Setter Property="Foreground" Value="#FFE05252"/>
                                            </Style>
                                            <Style Selector="TextBlock[Text=Error]">
                                                <Setter Property="Foreground" Value="#FFE05252"/>
                                            </Style>
                                        </TextBlock.Styles>
                                    </TextBlock>
                                </Border>

                                <!-- Error Detail (Full Width below Name) -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding ErrorMessage}"
                                           IsVisible="{Binding HasError}"
                                           Foreground="#FFE05252" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>

                                <!-- Progress Section -->
                                <ProgressBar Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                             IsVisible="{Binding IsDownloading}"
                                             Value="{Binding Progress}" Maximum="100" 
                                             Height="6" Margin="0,12,0,4"/>
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" 
                                           IsVisible="{Binding IsDownloading}"
                                           Text="{Binding ProgressText}"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
