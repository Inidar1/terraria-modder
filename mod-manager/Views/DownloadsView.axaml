<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TerrariaModManager.ViewModels"
             x:Class="TerrariaModManager.Views.DownloadsView"
             x:DataType="vm:DownloadsViewModel">
    <Grid Margin="24,24,24,36" RowDefinitions="Auto,Auto,*">

        <!-- Header with Clear Completed button -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Downloads" Classes="section-header"/>
            <Button Content="Clear Completed" Classes="secondary"
                    Command="{Binding ClearCompletedCommand}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Padding="10,4" FontSize="11"/>
        </Grid>

        <!-- Empty state -->
        <TextBlock Grid.Row="1"
                   Text="No downloads yet.&#x0a;Click 'Download with Vortex' on Nexus Mods or use the Browse tab."
                   Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center"
                   HorizontalAlignment="Center"
                   IsVisible="{Binding !Downloads.Count}"
                   Margin="0,40,0,0"/>

        <Border Grid.Row="2" Classes="card" IsVisible="{Binding Downloads.Count}">
            <ListBox ItemsSource="{Binding Downloads}"
                     Background="Transparent" BorderThickness="0">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="12,12,12,14"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderColorBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                    <Style Selector="ListBoxItem:last-child">
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:DownloadItem">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                              ColumnDefinitions="*,Auto,Auto">

                            <!-- Row 0 Col 0: Name + Nexus Page -->
                            <StackPanel Grid.Row="0" Grid.Column="0"
                                        Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <Button Content="Nexus Page" FontSize="10" Padding="8,2" Margin="12,0,0,0"
                                        Classes="secondary" VerticalAlignment="Center"
                                        Command="{Binding $parent[UserControl].DataContext.OpenOnNexusCommand}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>

                            <!-- Row 0 Col 1: Status badge -->
                            <Border Grid.Row="0" Grid.Column="1"
                                    Padding="6,2" CornerRadius="4" VerticalAlignment="Center"
                                    Background="{StaticResource BgDarkBrush}">
                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Styles>
                                        <Style Selector="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        </Style>
                                        <Style Selector="TextBlock[Text=Installed]">
                                            <Setter Property="Foreground" Value="#FF58EB1C"/>
                                        </Style>
                                        <Style Selector="TextBlock[Text=Installing...]">
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        </Style>
                                        <Style Selector="TextBlock[Text=Install Failed]">
                                            <Setter Property="Foreground" Value="#FFE05252"/>
                                        </Style>
                                        <Style Selector="TextBlock[Text=Failed]">
                                            <Setter Property="Foreground" Value="#FFE05252"/>
                                        </Style>
                                        <Style Selector="TextBlock[Text=Error]">
                                            <Setter Property="Foreground" Value="#FFE05252"/>
                                        </Style>
                                    </TextBlock.Styles>
                                </TextBlock>
                            </Border>

                            <!-- Row 0 Col 2: Dismiss (X) button for completed/failed -->
                            <Button Grid.Row="0" Grid.Column="2"
                                    Content="✕" FontSize="10"
                                    Padding="6,2" Margin="6,0,0,0"
                                    Classes="secondary" VerticalAlignment="Center"
                                    IsVisible="{Binding IsDone}"
                                    Command="{Binding $parent[UserControl].DataContext.DismissCommand}"
                                    CommandParameter="{Binding}"/>

                            <!-- Row 1: Error detail -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                       Text="{Binding ErrorMessage}"
                                       IsVisible="{Binding HasError}"
                                       Foreground="#FFE05252" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>

                            <!-- Row 2: Progress bar -->
                            <ProgressBar Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                         IsVisible="{Binding IsDownloading}"
                                         Value="{Binding Progress}" Maximum="100"
                                         Height="6" Margin="0,10,0,4"/>

                            <!-- Row 3: Progress text + speed + ETA -->
                            <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                  ColumnDefinitions="*,Auto,Auto"
                                  IsVisible="{Binding IsDownloading}">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding ProgressText}"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SpeedText}"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                           Margin="12,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding EtaText}"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                            </Grid>

                            <!-- Row 4: Retry button for failures -->
                            <Button Grid.Row="4" Grid.Column="0"
                                    Content="↺ Retry" FontSize="11"
                                    Padding="10,4" Margin="0,8,0,0"
                                    Classes="secondary"
                                    IsVisible="{Binding HasError}"
                                    Command="{Binding $parent[UserControl].DataContext.RetryCommand}"
                                    CommandParameter="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</UserControl>
