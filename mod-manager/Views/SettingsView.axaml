<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TerrariaModManager.Views.SettingsView">
    <Grid RowDefinitions="Auto,*">

        <!-- Header row: title + tab switcher -->
        <Grid Grid.Row="0" Margin="24,24,24,0" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="Settings" Classes="section-header" Margin="0"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                <Button Content="Settings" Padding="14,6" FontSize="13"
                        Command="{Binding ShowSettingsTabCommand}"
                        Classes="secondary"
                        Classes.active="{Binding ShowSettings}"/>
                <Button Content="Logs" Padding="14,6" FontSize="13"
                        Command="{Binding ShowLogsTabCommand}"
                        Classes="secondary"
                        Classes.active="{Binding ShowLogs}"/>
            </StackPanel>
        </Grid>

        <!-- SETTINGS PANEL -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding ShowSettings}">
            <StackPanel MaxWidth="800" HorizontalAlignment="Left" Margin="24,16,24,36" Spacing="12">

                <!-- Game section -->
                <Border Classes="card">
                    <StackPanel Spacing="14">
                        <TextBlock Text="GAME" Classes="label" FontWeight="SemiBold"/>

                        <!-- Install path row -->
                        <Grid RowDefinitions="Auto,Auto,Auto">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
                                <TextBox Grid.Column="0" Text="{Binding TerrariaPath}"
                                         Classes="dark"
                                         Classes.invalid="{Binding !IsPathValid}"
                                         Watermark="Path to Terraria folder"/>
                                <Button Grid.Column="1" Content="Browse" Classes="secondary"
                                        Command="{Binding BrowsePathCommand}" Margin="8,0,0,0"/>
                                <Button Grid.Column="2" Content="Auto-detect" Classes="primary"
                                        Command="{Binding AutoDetectCommand}" Margin="8,0,0,0"/>
                            </Grid>
                            <TextBlock Grid.Row="1"
                                       Text="Path not found or doesn't contain Terraria.exe"
                                       Foreground="{StaticResource DangerBrush}" FontSize="11"
                                       Margin="0,4,0,0"
                                       IsVisible="{Binding !IsPathValid}"/>
                        </Grid>

                        <!-- Core status row -->
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="TerrariaModder Core" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Required framework for mods to load"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center" Spacing="6">
                                <Ellipse Width="8" Height="8" Fill="{Binding CoreStatusColor}"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CoreStatusText}"
                                           Foreground="{Binding CoreStatusColor}"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Nexus Account section -->
                <Border Classes="card">
                    <StackPanel Spacing="14">
                        <TextBlock Text="NEXUS MODS ACCOUNT" Classes="label" FontWeight="SemiBold"/>

                        <!-- Logged in -->
                        <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding IsLoggedIn}">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding UserName}" FontSize="14" FontWeight="SemiBold"/>
                                    <Border Background="{StaticResource AccentSubtleBrush}" CornerRadius="3"
                                            Padding="6,2" VerticalAlignment="Center"
                                            IsVisible="{Binding IsPremium}">
                                        <TextBlock Text="Premium" FontSize="10"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Logged in to Nexus Mods" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Logout" Classes="secondary"
                                    Command="{Binding LogoutCommand}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Not logged in -->
                        <StackPanel IsVisible="{Binding !IsLoggedIn}" Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Sign in with Nexus Mods" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Recommended — opens a browser window to log in securely"
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Login with Nexus Mods" Classes="primary"
                                        Command="{Binding LoginWithNexusCommand}"
                                        IsEnabled="{Binding !IsLoggingIn}"
                                        VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="{Binding LoginStatus}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" TextWrapping="Wrap"
                                       IsVisible="{Binding LoginStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                            <!-- Divider -->
                            <Border Height="1" Background="{StaticResource BorderColorBrush}" Margin="0,2"/>

                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="API Key" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Enter your Nexus Mods API key manually"
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                            VerticalAlignment="Center">
                                    <TextBox Text="{Binding ApiKey}" Classes="dark"
                                             PasswordChar="•" Width="200"/>
                                    <Button Content="Save" Classes="primary"
                                            Command="{Binding SaveManualKeyCommand}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Preferences section -->
                <Border Classes="card">
                    <StackPanel Spacing="14">
                        <TextBlock Text="PREFERENCES" Classes="label" FontWeight="SemiBold"/>

                        <!-- NXM handler row -->
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="Vortex Download Button" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <Border Background="#14AAAAAA" BorderBrush="#60AAAAAA" BorderThickness="1"
                                            CornerRadius="3" Padding="4,1" VerticalAlignment="Center">
                                        <TextBlock Text="Experimental" FontSize="9"
                                                   Foreground="#FFAAAAAA"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Register Vault for 'Vortex' download links"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Ellipse Width="8" Height="8" Fill="{Binding NxmStatusColor}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding NxmStatusText}"
                                               Foreground="{Binding NxmStatusColor}"
                                               FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Content="{Binding NxmButtonText}" Classes="secondary"
                                        Command="{Binding RegisterNxmCommand}"/>
                                <Button Content="Unregister" Classes="secondary"
                                        Command="{Binding UnregisterNxmCommand}"
                                        IsVisible="{Binding IsNxmRegistered}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Divider -->
                        <Border Height="1" Background="{StaticResource BorderColorBrush}"/>

                        <!-- Auto-update row -->
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Auto-check for Updates" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Check for mod updates when switching to the Installed tab"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoCheckForUpdates}"
                                          OnContent="" OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Troubleshooting section -->
                <Border Classes="card">
                    <StackPanel Spacing="14">
                        <TextBlock Text="TROUBLESHOOTING" Classes="label" FontWeight="SemiBold"/>

                        <!-- Reset WebView row -->
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Reset Browser" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="If the mod browser shows a black screen, reset WebView data and restart"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Reset &amp; Restart" Classes="secondary"
                                    Command="{Binding ResetWebViewCommand}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- LOGS PANEL -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="24,16,24,24"
              IsVisible="{Binding ShowLogs}">
            <!-- Toolbar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="0,0,0,10">
                <Button Content="Refresh" Classes="secondary" Padding="12,5" FontSize="12"
                        Command="{Binding RefreshLogsCommand}"/>
                <Button Content="Copy" Classes="secondary" Padding="12,5" FontSize="12"
                        Command="{Binding CopyLogsCommand}"/>
                <Button Content="Save as .txt" Classes="secondary" Padding="12,5" FontSize="12"
                        Command="{Binding SaveLogsCommand}"/>
                <Button Content="Clear" Classes="secondary" Padding="12,5" FontSize="12"
                        Command="{Binding ClearLogsCommand}"/>
            </StackPanel>

            <!-- Log output -->
            <Border Grid.Row="1" Classes="card" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Padding="10,8">
                    <TextBlock Text="{Binding LogText}"
                               FontFamily="Consolas,Courier New,monospace"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="NoWrap"/>
                </ScrollViewer>
            </Border>
        </Grid>

    </Grid>
</UserControl>
